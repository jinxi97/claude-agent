# Claude API key (required by the Claude Code CLI subprocess)
# ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_CODE_USE_VERTEX=1

# --- Set automatically at runtime (do NOT set manually) ---
# CHAT_ID        – injected per-session so publish.py knows which chat owns a file
# WORKSPACE_ROOT – injected per-session so the skill writes artifacts to the project root
